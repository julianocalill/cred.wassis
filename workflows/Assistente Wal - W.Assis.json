    {
      "parameters": {
        "jsCode": "const text = $input.first().json.text || \"\";\nlet cleanText = text;\nlet labelTag = null;\n\n// Procura pelas tags secretas da IA e extrai o rótulo da área\nif (text.includes(\"[TRANSFERIR_VENDAS]\")) {\n  cleanText = text.replace(\"[TRANSFERIR_VENDAS]\", \"\").trim();\n  labelTag = \"Vendas\";\n} else if (text.includes(\"[TRANSFERIR_FINANCEIRO]\")) {\n  cleanText = text.replace(\"[TRANSFERIR_FINANCEIRO]\", \"\").trim();\n  labelTag = \"Financeiro\";\n} else if (text.includes(\"[TRANSFERIR_SINISTRO]\")) {\n  cleanText = text.replace(\"[TRANSFERIR_SINISTRO]\", \"\").trim();\n  labelTag = \"Sinistro\";\n}\n\nreturn {\n  clean_text: cleanText,\n  label: labelTag,\n  conversation_id: $('Webhook Chatwoot1').item.json.body.conversation.id\n};"
      },
