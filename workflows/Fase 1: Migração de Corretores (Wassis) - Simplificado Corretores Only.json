      {
        "id": "transform_simple_v11_v2",
        "name": "TransformDataCSV",
        "parameters": {
          "jsCode": "const csv = $json.csv_raw;\nconst lines = csv.split('\\n');\nconst results = [];\n\nfor (let i = 1; i < lines.length; i++) {\n  if (!lines[i]) continue;\n  const currentLine = lines[i].split('\",\"');\n  const obj = {};\n  \n  obj.email = currentLine[21]?.replace(/\"/g, '') || '';\n  obj.nome_completo = currentLine[10]?.replace(/\"/g, '') || '';\n  obj.perfil = currentLine[1] || 'Vendedor';\n  obj.bubble_id = currentLine[23]?.replace(/\"/g, '') || '';\n  obj.avatar_url = (currentLine[8] && currentLine[8].length > 5) ? 'https:' + currentLine[8].replace(/\"/g, '') : '';\n  \n  if (obj.email) results.push({ json: obj });\n}\nreturn results;"
        },
        "position": [
          600,
          240
        ],
        "type": "n8n-nodes-base.code",
        "typeVersion": 1
      },
      {
        "credentials": {
          "postgres": {
            "id": "4hBCxfGMrrXEqEmj",
            "name": "Supabase"
          }
        },
        "id": "get_sup_simple_v11",
        "name": "GetSupabaseCorretores",
        "parameters": {
          "operation": "executeQuery",
          "query": "SELECT id, nome_completo, bubble_id FROM public.corretores;"
        },
        "position": [
          800,
          240
        ],
        "type": "n8n-nodes-base.postgres",
        "typeVersion": 2.6
      },
      {
        "id": "upsert_logic_simple_v11",
        "name": "PrepararUpsertSQL",
        "parameters": {
          "jsCode": "const bubbleItems = $(\"TransformDataCSV\").all();\nconst supabaseItems = $(\"GetSupabaseCorretores\").all();\n\nreturn bubbleItems.map(item => {\n  const d = item.json;\n  const match = supabaseItems.find(s => \n    (s.json.bubble_id && s.json.bubble_id === d.bubble_id) ||\n    (d.nome_completo === 'Renato' && s.json.nome_completo === 'Renato') ||\n    (d.nome_completo.includes('Vinicius') && s.json.nome_completo.includes('Vinicius'))\n  );\n  \n  if (match) {\n    return { json: { ...d, id: match.json.id, type: 'update' } };\n  } else {\n    return { json: { ...d, type: 'create' } };\n  }\n});"
        },
        "position": [
          1000,
          240
        ],
        "type": "n8n-nodes-base.code",
        "typeVersion": 1
      },
      {
        "id": "wait_simple_v11",
        "name": "WaitToSplit",
        "parameters": {
          "jsCode": "return items;"
