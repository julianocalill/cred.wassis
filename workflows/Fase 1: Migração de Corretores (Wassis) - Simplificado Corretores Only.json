          }
        },
        "id": "up_post_simple_v11_v2",
        "name": "UpdateExistentesPostgres",
        "parameters": {
          "operation": "executeQuery",
          "query": "={{ \"UPDATE public.corretores SET nome_completo = '\" + $json.nome_completo.replace(/'/g, \"''\") + \"', perfil = '\" + $json.perfil + \"', bubble_id = '\" + $json.bubble_id + \"', avatar_url = NULLIF('\" + $json.avatar_url + \"', '') WHERE id = '\" + $json.id + \"'::uuid;\" }}"
        },
        "position": [
          1650,
          150
        ],
        "type": "n8n-nodes-base.postgres",
        "typeVersion": 2.6
