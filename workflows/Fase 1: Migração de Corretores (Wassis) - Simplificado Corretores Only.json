        },
        "id": "ins_nov_simple_v11_v2_new",
        "name": "InsertNovosPostgres",
        "parameters": {
          "operation": "executeQuery",
          "query": "={{ \"INSERT INTO public.corretores (id, nome_completo, perfil, bubble_id, avatar_url) VALUES (gen_random_uuid(), '\" + $json.nome_completo.replace(/'/g, \"''\") + \"', '\" + $json.perfil + \"', '\" + $json.bubble_id + \"', NULLIF('\" + $json.avatar_url + \"', ''));\" }}"
        },
        "position": [
          1650,
          350
        ],
