        ],
        "type": "n8n-nodes-base.code",
        "typeVersion": 1
      },
      {
        "id": "switch_simple_v11",
        "name": "CheckAcao",
        "parameters": {
          "dataType": "string",
          "rules": {
            "rules": [
              {
                "operation": "equal",
                "value": "update"
              },
              {
                "operation": "equal",
                "value": "create"
              }
            ]
          },
          "value": "={{ $json.type }}"
        },
        "position": [
          1400,
